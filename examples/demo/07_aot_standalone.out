    # src[07_aot_standalone.py:20-23]: ...
    _launcher(_helion_rms_norm_c0, (triton.cdiv(m, _BLOCK_SIZE_0_c0),), x, weight, out, out.stride(0), out.stride(1), weight.stride(0), x.stride(0), x.stride(1), m, n, eps, _RDIM_SIZE_1, num_warps=8, num_stages=1)
